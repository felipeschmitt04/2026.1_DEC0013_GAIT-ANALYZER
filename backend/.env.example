# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Storage
UPLOAD_DIR=storage/uploads
RESULTS_DIR=storage/results
TEMP_DIR=storage/temp

# Processing
WINDOW_L=150

# Mock mode
# Set true to test API/frontend/storage without loading IA/GPU models.
USE_MOCK_ENGINE=false

# Engine selection
# mock: use MockGaitAnalysisEngine
# local: load GaitAnalysisEngine in this process
# remote: call the DGX worker API defined by REMOTE_ENGINE_URL
ENGINE_MODE=local
REMOTE_ENGINE_URL=http://localhost:9000
REMOTE_ENGINE_TIMEOUT_S=3600

# CORS
# Use comma-separated origins in production, for example:
# CORS_ORIGINS=https://frontend.example.com,http://localhost:3000
CORS_ORIGINS=*
